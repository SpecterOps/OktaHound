{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary",
        "--nologo"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run",
      "command": "dotnet",
      "type": "process",
      "args": [
        "run",
        "--project",
        "Src/SpecterOps.OktaHound/SpecterOps.OktaHound.csproj",
        "--nologo"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "clean",
      "command": "dotnet",
      "type": "process",
      "args": [
        "clean",
        "--nologo"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "publish",
      "type": "shell",
      "command": "dotnet publish -r win-x64 --nologo; dotnet publish -r win-arm64 --nologo; dotnet publish -r linux-x64 --nologo; dotnet publish -r linux-arm --nologo; dotnet publish -r linux-arm64 --nologo; dotnet publish -r osx-arm64 --nologo; dotnet publish -r osx-x64 --nologo",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile"
    }
  ]
}
